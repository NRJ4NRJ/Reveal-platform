# ── Azure AD (user-facing app registration) ───────────────────
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# ── Service URLs ──────────────────────────────────────────────
# Local Docker example:
# PYTHON_SERVICE_URL=http://localhost:8000
# Online example:
# PYTHON_SERVICE_URL=https://reveal-analysis-service.up.railway.app
PYTHON_SERVICE_URL=http://localhost:8000

# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-hex-32
# Local Docker example:
# NEXTAUTH_URL=http://localhost:3000
# Online example:
# NEXTAUTH_URL=https://reveal.your-domain.com
NEXTAUTH_URL=http://localhost:3000

# ── Password Reset Email (optional, enables email delivery) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASSWORD=change-me
SMTP_FROM="REVEAL <no-reply@example.com>"
SMTP_SECURE=false

# ── Analysis service / ERA data (optional) ────────────────────
CDS_API_URL=
CDS_API_KEY=

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
