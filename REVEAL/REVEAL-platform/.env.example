# ── Supabase / PostgreSQL ─────────────────────────────────────
# Transaction pooler – runtime app connections (pgBouncer, port 6543)
# Supabase > Settings > Database > Connection pooling > Transaction mode
DATABASE_URL="postgresql://postgres.nanbukycdlgrxyohjek:[PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true"

# Direct connection – Prisma migrations only (port 5432)
# Supabase > Settings > Database > Connection string > URI
DIRECT_URL="postgresql://postgres.nanbukycdlgrxyohjek:[PASSWORD]@db.nanbukycdlgrxyohjek.supabase.co:5432/postgres"

# Supabase public API keys
# Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://nanbukycdlgrxyohjek.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Azure AD (user-facing app registration) ───────────────────
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Service URLs ──────────────────────────────────────────────
# Analysis service (Railway or local)
PYTHON_SERVICE_URL=http://localhost:8000

# ── NextAuth ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# ── Password Reset Email (optional) ──────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASSWORD=change-me
SMTP_FROM="REVEAL <no-reply@example.com>"
SMTP_SECURE=false

# ── ERA5 Climate Data Store (optional) ───────────────────────
CDS_API_URL=
CDS_API_KEY=

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
