# Supabase PostgreSQL — session pooler (eu-west-1) compatible Prisma
# Remplacer [YOUR-DB-PASSWORD] par le mot de passe du projet Supabase
# (Dashboard > Settings > Database > Connection string)
DATABASE_URL="postgresql://postgres.wydcxokrqvxwjkxlugjr:[YOUR-DB-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"

# JWT — générer avec : openssl rand -base64 48
JWT_SECRET="change_me_super_secret_jwt_key_48chars_min"
JWT_REFRESH_SECRET="change_me_refresh_secret_key_48chars_min"

PORT=4000
FRONTEND_URL="https://safety-skill-track.vercel.app"
CORS_ORIGIN="https://safety-skill-track.vercel.app"

SUPABASE_URL="https://wydcxokrqvxwjkxlugjr.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SUPABASE-SERVICE-ROLE-KEY]"
SUPABASE_STORAGE_BUCKET="branding-assets"
UPLOAD_DIR="./uploads"
