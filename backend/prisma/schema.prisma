generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlatformSettings {
  id           Int     @id @default(autoincrement())
  primaryColor String  @default("#27295A")
  accentColor  String  @default("#FCC00E")
  logoUrl      String?
}

model Client {
  id             Int        @id @default(autoincrement())
  name           String
  address        String?
  siret          String?
  sector         String?
  contactName    String?
  contactEmail   String?
  phone          String?
  website        String?
  postalCode     String?    // ITER7: code postal
  city           String?    // ITER7: ville
  country        String?    // ITER7: pays
  state          String?    // ITER10: état US
  primaryColor   String     @default("#27295A")
  accentColor    String     @default("#FCC00E")
  logoUrl        String?
  adminPassword  String?    // ITER11: dernier mot de passe admin généré (en clair, pour affichage SA)
  updatedByAdmin Boolean    @default(false)
  users          User[]
  employees      Employee[]
  testSelections TestSelection[]
  clientTests    ClientTest[]
  receivedMessages Message[] @relation("ReceivedMessages")
  createdAt      DateTime   @default(now())
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  username     String    @unique
  password     String
  role         Role
  language                 String    @default("fr")
  pendingEmail             String?   // ITER10: email en attente de vérification
  emailVerificationToken   String?   // ITER10: token de vérification
  clientId     Int?
  client       Client?   @relation(fields: [clientId], references: [id])
  refreshTokens RefreshToken[]
  employee     Employee?
  resetTokens  PasswordResetToken[]
  sentMessages Message[] @relation("SentMessages")
  notifications Notification[]
  createdAt    DateTime  @default(now())
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Message {
  id              Int      @id @default(autoincrement())
  senderUserId    Int
  sender          User     @relation("SentMessages", fields: [senderUserId], references: [id])
  toClientId      Int?
  recipientClient Client?  @relation("ReceivedMessages", fields: [toClientId], references: [id])
  subject         String
  body            String
  senderName      String?
  senderEmail     String?
  testName        String?
  subSubThemeName String?
  isHandled       Boolean  @default(false)
  // ITER11: reply + forward
  replyText                String?
  repliedAt                DateTime?
  forwardedToSuperAdmin    Boolean  @default(false)
  forwardedAt              DateTime?
  createdAt       DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("TEST_COMPLETED")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ITER8: modèle pour les réponses ouvertes (OPEN / SCENARIO) à corriger manuellement
model OpenResponse {
  id               Int          @id @default(autoincrement())
  employeeId       Int
  employee         Employee     @relation(fields: [employeeId], references: [id])
  sessionId        Int
  session          TestSession  @relation(fields: [sessionId], references: [id])
  questionId       Int
  question         Question     @relation(fields: [questionId], references: [id])
  questionType     String       // "OPEN" | "SCENARIO"
  responseText     String
  reviewerFeedback String?
  score            Float?
  isReviewed       Boolean      @default(false)
  reviewedAt       DateTime?
  reviewedById     Int?
  createdAt        DateTime     @default(now())
}

model Theme {
  id        Int        @id @default(autoincrement())
  label     String
  nameEn    String?    // ITER11: traduction EN
  subThemes SubTheme[]

  @@unique([label])
}

model SubTheme {
  id           Int          @id @default(autoincrement())
  label        String
  nameEn       String?      // ITER11: traduction EN
  themeId      Int
  theme        Theme        @relation(fields: [themeId], references: [id])
  subSubThemes SubSubTheme[]
}

model SubSubTheme {
  id         Int       @id @default(autoincrement())
  label      String
  subThemeId Int
  subTheme   SubTheme  @relation(fields: [subThemeId], references: [id])
  questions  Question[]
}

model Question {
  id             Int          @id @default(autoincrement())
  text           String
  type           QuestionType
  level          Level
  subSubThemeId  Int
  subSubTheme    SubSubTheme  @relation(fields: [subSubThemeId], references: [id])
  options        Json?
  expectedAnswer String?
  correctAnswers    String[]     @default([]) // ITER11: tableau de bonnes réponses (QCM multi-réponses)
  textEn            String?      // ITER12: traduction EN du texte de la question
  correctAnswersEn  String[]     @default([]) // ITER12: bonnes réponses EN
  distractorsEn     String[]     @default([]) // ITER12: distracteurs EN
  customScore       Int?         // ITER10: score personnalisé (null = barème par niveau: F=1,B=2,I=3,A=4,C=5)
  openResponses  OpenResponse[] // ITER8: réponses ouvertes liées à cette question
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Employee {
  id            Int              @id @default(autoincrement())
  lastName      String
  firstName     String
  birthDate     DateTime?
  position      String?
  department    String?
  site          String?
  country       String?
  language      String?
  email         String           @unique
  isActive      Boolean          @default(true)
  clientId      Int
  client        Client           @relation(fields: [clientId], references: [id])
  userId        Int?             @unique
  user          User?            @relation(fields: [userId], references: [id])
  plainPassword String?
  assignments   TestAssignment[]
  sessions      TestSession[]
  openResponses OpenResponse[]   // ITER8: réponses ouvertes
  createdAt     DateTime         @default(now())
}

model TestSelection {
  id        Int     @id @default(autoincrement())
  clientId  Int
  client    Client  @relation(fields: [clientId], references: [id])
  themeId   Int
  selected  Boolean @default(false)

  @@unique([clientId, themeId])
}

model Test {
  id            Int              @id @default(autoincrement())
  name          String
  description   String?
  timerEnabled  Boolean          @default(false)
  timerDuration Int?
  competences   TestCompetence[]
  assignments   TestAssignment[]
  clientTests   ClientTest[]
  sessions      TestSession[]
  createdAt     DateTime         @default(now())
}

model TestCompetence {
  id            Int     @id @default(autoincrement())
  testId        Int
  test          Test    @relation(fields: [testId], references: [id], onDelete: Cascade)
  subSubThemeId Int?
  subThemeId    Int?
  questionCount Int     @default(2)
  expectedLevel Level   @default(FONDAMENTAL)
}

model ClientTest {
  id         Int               @id @default(autoincrement())
  clientId   Int
  client     Client            @relation(fields: [clientId], references: [id])
  testId     Int
  test       Test              @relation(fields: [testId], references: [id])
  assignedAt DateTime          @default(now())
  levels     ClientTestLevel[]
  @@unique([clientId, testId])
}

model ClientTestLevel {
  id            Int        @id @default(autoincrement())
  clientTestId  Int
  clientTest    ClientTest @relation(fields: [clientTestId], references: [id], onDelete: Cascade)
  subSubThemeId Int
  expectedLevel Level      @default(FONDAMENTAL)
  @@unique([clientTestId, subSubThemeId])
}

model TestAssignment {
  id         Int              @id @default(autoincrement())
  testId     Int
  test       Test             @relation(fields: [testId], references: [id])
  employeeId Int
  employee   Employee         @relation(fields: [employeeId], references: [id])
  deadline   DateTime?
  assignedAt DateTime         @default(now())
  status     AssignmentStatus @default(PENDING)
  @@unique([testId, employeeId])
}

model TestSession {
  id               Int                    @id @default(autoincrement())
  testId           Int
  test             Test                   @relation(fields: [testId], references: [id])
  employeeId       Int
  employee         Employee               @relation(fields: [employeeId], references: [id])
  status           SessionStatus          @default(IN_PROGRESS)
  progress         TestSessionProgress[]
  openResponses    OpenResponse[]         // ITER8: réponses ouvertes
  timeRemaining    Int?
  attemptNumber    Int                    @default(1) // ITER9: numéro de tentative pour les retakes
  askedQuestionIds Int[]                  @default([]) // ITER11: anti-boucle — IDs déjà posés
  startedAt        DateTime               @default(now())
  completedAt      DateTime?
}

model TestSessionProgress {
  id             Int         @id @default(autoincrement())
  sessionId      Int
  session        TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  subSubThemeId  Int
  currentLevel   Level       @default(FONDAMENTAL)
  questionsAsked Int         @default(0)
  correctCount   Int         @default(0)
  completed           Boolean     @default(false)
  passed              Boolean     @default(false)
  levelQuestionsAsked Int         @default(0)  // ITER10: questions auto posées au niveau courant
  levelOpenAsked      Int         @default(0)  // ITER11: questions open/scenario posées au niveau courant
  levelCorrectCount   Int         @default(0)  // ITER10: bonnes réponses au niveau courant
  levelReached        Level?                   // ITER10: niveau maximum atteint pour ce SST
  pointsEarned        Int         @default(0)  // ITER10: points gagnés (barème par niveau)
  maxPoints           Int         @default(0)  // ITER10: points max possibles
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum Role {
  SUPER_ADMIN
  CLIENT_ADMIN
  EMPLOYEE
}

enum QuestionType {
  QCM
  TRUE_FALSE
  OPEN
  SCENARIO
  RANKING
}

enum Level {
  FONDAMENTAL
  BASIQUE
  INTERMEDIAIRE
  AVANCE
  COMPLET
}
