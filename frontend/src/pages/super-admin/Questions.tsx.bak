import React, { useEffect, useRef, useState } from "react";
import Sidebar from "../../components/Sidebar";
import { useAuth } from "../../contexts/AuthContext";
import { useBranding } from "../../contexts/BrandingContext";
import toast from "react-hot-toast";
import { Plus, Pencil, X, FileSpreadsheet, Upload, AlertTriangle, Download } from "lucide-react";
import * as XLSX from "xlsx";

interface Theme { id: number; label: string; subThemes: SubTheme[]; }
interface SubTheme { id: number; label: string; themeId: number; subSubThemes: SubSubTheme[]; }
interface SubSubTheme { id: number; label: string; subThemeId: number; }
interface Question {
  id: number;
  text: string;
  type: string;
  level: string;
  subSubThemeId: number;
  options: any;
  expectedAnswer: string | null;
  subSubTheme: {
    label: string;
    subTheme: {
      label: string;
      theme: { label: string };
    };
  };
}

interface ImportQuestion {
  grand_theme: string;
  sous_theme: string;
  sous_sous_theme: string;
  type: string;
  niveau: string;
  enonce: string;
  reponse_correcte: string;
  distracteur_1: string;
  distracteur_2: string;
  distracteur_3: string;
  _rowIndex: number;
  _error?: string;
}

const QUESTION_TYPES = ["QCM", "TRUE_FALSE", "OPEN", "SCENARIO", "RANKING"];
const LEVELS = ["FONDAMENTAL", "BASIQUE", "INTERMEDIAIRE", "AVANCE", "COMPLET"];

const typeLabels: Record<string, string> = {
  QCM: "QCM",
  TRUE_FALSE: "Vrai / Faux",
  OPEN: "Question ouverte",
  SCENARIO: "Scénario",
  RANKING: "Classement",
};

const levelLabels: Record<string, string> = {
  FONDAMENTAL: "Fondamental",
  BASIQUE: "Basique",
  INTERMEDIAIRE: "Intermédiaire",
  AVANCE: "Avancé",
  COMPLET: "Complet",
};

function Modal({ title, onClose, children, wide }: { title: string; onClose: () => void; children: React.ReactNode; wide?: boolean }) {
  return (
    <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
      <div className={`bg-white rounded-xl shadow-xl w-full ${wide ? "max-w-4xl" : "max-w-lg"} max-h-[90vh] flex flex-col`}>
        <div className="flex items-center justify-between p-5 border-b">
          <h2 className="text-lg font-semibold">{title}</h2>
          <button onClick={onClose} className="text-gray-400 hover:text-gray-600"><X size={20} /></button>
        </div>
        <div className="flex-1 overflow-y-auto p-5">{children}</div>
      </div>
    </div>
  );
}

export default function SuperAdminQuestions() {
  const { accessToken } = useAuth();
  const branding = useBranding();

  const [themes, setThemes] = useState<Theme[]>([]);
  const [questions, setQuestions] = useState<Question[]>([]);
  const [loading, setLoading] = useState(true);

  // Modal state
  const [showThemeModal, setShowThemeModal] = useState(false);
  const [showSubThemeModal, setShowSubThemeModal] = useState(false);
  const [showSubSubThemeModal, setShowSubSubThemeModal] = useState(false);
  const [showQuestionModal, setShowQuestionModal] = useState(false);
  const [editingQuestion, setEditingQuestion] = useState<Question | null>(null);

  // Import state
  const [showImportModal, setShowImportModal] = useState(false);
  const [importRows, setImportRows] = useState<ImportQuestion[]>([]);
  const [importSaving, setImportSaving] = useState(false);
  const importFileRef = useRef<HTMLInputElement>(null);

  // Form state - theme
  const [themeLabel, setThemeLabel] = useState("");

  // Form state - sub-theme
  const [subThemeLabel, setSubThemeLabel] = useState("");
  const [subThemeThemeId, setSubThemeThemeId] = useState("");

  // Form state - sub-sub-theme
  const [subSubThemeLabel, setSubSubThemeLabel] = useState("");
  const [subSubThemeSubThemeId, setSubSubThemeSubThemeId] = useState("");

  // Form state - question
  const [qText, setQText] = useState("");
  const [qType, setQType] = useState("QCM");
  const [qLevel, setQLevel] = useState("FONDAMENTAL");
  const [qThemeId, setQThemeId] = useState("");
  const [qSubThemeId, setQSubThemeId] = useState("");
  const [qSubSubThemeId, setQSubSubThemeId] = useState("");
  const [qExpectedAnswer, setQExpectedAnswer] = useState("");
  const [qOptions, setQOptions] = useState<string[]>(["", "", "", ""]);
  const [qCorrectOption, setQCorrectOption] = useState(0);
  const [qTrueFalse, setQTrueFalse] = useState<"true" | "false">("true");
  const [qRankingItems, setQRankingItems] = useState<string[]>(["", "", ""]);
  const [saving, setSaving] = useState(false);

  const headers = { Authorization: `Bearer ${accessToken}`, "Content-Type": "application/json" };

  async function loadData() {
    if (!accessToken) return;
    setLoading(true);
    try {
      const [themesRes, questionsRes] = await Promise.all([
        fetch("/api/super-admin/themes", { headers }),
        fetch("/api/super-admin/questions", { headers }),
      ]);
      setThemes(await themesRes.json());
      setQuestions(await questionsRes.json());
    } catch {
      toast.error("Erreur de chargement");
    } finally {
      setLoading(false);
    }
  }

  useEffect(() => { loadData(); }, [accessToken]);

  // Derived lists
  const subThemesForSelected = themes.find(t => t.id === Number(qThemeId))?.subThemes || [];
  const subSubThemesForSelected = subThemesForSelected.find(s => s.id === Number(qSubThemeId))?.subSubThemes || [];

  const allSubThemes = themes.flatMap(t => t.subThemes);

  async function handleCreateTheme(e: React.FormEvent) {
    e.preventDefault();
    try {
      const res = await fetch("/api/super-admin/themes", {
        method: "POST", headers, body: JSON.stringify({ label: themeLabel }),
      });
      if (!res.ok) throw new Error();
      toast.success("Thème créé");
      setThemeLabel("");
      setShowThemeModal(false);
      loadData();
    } catch {
      toast.error("Erreur lors de la création");
    }
  }

  async function handleCreateSubTheme(e: React.FormEvent) {
    e.preventDefault();
    try {
      const res = await fetch("/api/super-admin/sub-themes", {
        method: "POST", headers, body: JSON.stringify({ label: subThemeLabel, themeId: Number(subThemeThemeId) }),
      });
      if (!res.ok) throw new Error();
      toast.success("Sous-thème créé");
      setSubThemeLabel(""); setSubThemeThemeId("");
      setShowSubThemeModal(false);
      loadData();
    } catch {
      toast.error("Erreur lors de la création");
    }
  }

  async function handleCreateSubSubTheme(e: React.FormEvent) {
    e.preventDefault();
    try {
      const res = await fetch("/api/super-admin/sub-sub-themes", {
        method: "POST", headers, body: JSON.stringify({ label: subSubThemeLabel, subThemeId: Number(subSubThemeSubThemeId) }),
      });
      if (!res.ok) throw new Error();
      toast.success("Sous-sous-thème créé");
      setSubSubThemeLabel(""); setSubSubThemeSubThemeId("");
      setShowSubSubThemeModal(false);
      loadData();
    } catch {
      toast.error("Erreur lors de la création");
    }
  }

  function buildOptions() {
    if (qType === "QCM") {
      return { choices: qOptions.filter(o => o.trim()), correctIndex: qCorrectOption };
    }
    if (qType === "TRUE_FALSE") {
      return { answer: qTrueFalse };
    }
    if (qType === "RANKING") {
      return { items: qRankingItems.filter(i => i.trim()) };
    }
    return null;
  }

  function openEditQuestion(q: Question) {
    setEditingQuestion(q);
    setQText(q.text);
    setQType(q.type);
    setQLevel(q.level);
    setQSubSubThemeId(String(q.subSubThemeId));
    setQExpectedAnswer(q.expectedAnswer || "");
    if (q.type === "QCM" && q.options) {
      setQOptions(q.options.choices || ["", "", "", ""]);
      setQCorrectOption(q.options.correctIndex ?? 0);
    }
    if (q.type === "TRUE_FALSE" && q.options) {
      setQTrueFalse(q.options.answer || "true");
    }
    if (q.type === "RANKING" && q.options) {
      setQRankingItems(q.options.items || ["", "", ""]);
    }
    // Set theme/subtheme from question
    const sst = themes.flatMap(t => t.subThemes.flatMap(s => s.subSubThemes.map(ss => ({ ...ss, subTheme: s, theme: t })))).find(ss => ss.id === q.subSubThemeId);
    if (sst) {
      setQThemeId(String(sst.theme.id));
      setQSubThemeId(String(sst.subTheme.id));
    }
    setShowQuestionModal(true);
  }

  function resetQuestionForm() {
    setQText(""); setQType("QCM"); setQLevel("FONDAMENTAL");
    setQThemeId(""); setQSubThemeId(""); setQSubSubThemeId("");
    setQExpectedAnswer(""); setQOptions(["", "", "", ""]);
    setQCorrectOption(0); setQTrueFalse("true"); setQRankingItems(["", "", ""]);
    setEditingQuestion(null);
  }

  async function handleSaveQuestion(e: React.FormEvent) {
    e.preventDefault();
    if (!qSubSubThemeId) { toast.error("Sélectionnez un sous-sous-thème"); return; }
    setSaving(true);
    try {
      const body = {
        text: qText, type: qType, level: qLevel,
        subSubThemeId: Number(qSubSubThemeId),
        options: buildOptions(),
        expectedAnswer: qExpectedAnswer || null,
      };
      const url = editingQuestion ? `/api/super-admin/questions/${editingQuestion.id}` : "/api/super-admin/questions";
      const method = editingQuestion ? "PUT" : "POST";
      const res = await fetch(url, { method, headers, body: JSON.stringify(body) });
      if (!res.ok) throw new Error();
      toast.success(editingQuestion ? "Question modifiée" : "Question créée");
      resetQuestionForm();
      setShowQuestionModal(false);
      loadData();
    } catch {
      toast.error("Erreur lors de l'enregistrement");
    } finally {
      setSaving(false);
    }
  }

  // Excel import for questions
  function parseQuestionsExcel(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const data = new Uint8Array(e.target?.result as ArrayBuffer);
        const workbook = XLSX.read(data, { type: "array" });
        const sheet = workbook.Sheets[workbook.SheetNames[0]];
        const raw: any[] = XLSX.utils.sheet_to_json(sheet, { header: 1 });

        if (raw.length < 2) {
          toast.error("Le fichier est vide ou mal formaté");
          return;
        }

        // Normalize string: lowercase + remove accents + collapse spaces/underscores
        const normalize = (s: string) =>
          String(s || "")
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/[^a-z0-9]+/g, " ")
            .trim();

        const fileHeaders = (raw[0] as any[]).map(h => normalize(h));

        // Synonym groups for each field
        const SYNONYMS: Record<string, string[]> = {
          grand_theme:      ["grand theme", "grand themes", "theme", "themes", "categorie", "domaine"],
          sous_theme:       ["sous theme", "sous themes", "subtheme", "sous categorie"],
          sous_sous_theme:  ["sous sous theme", "sous sous themes", "sous sous", "subsubtheme", "sous theme 2", "sous categorie 2"],
          type:             ["type", "type de question", "type question", "format"],
          niveau:           ["niveau", "level", "difficulte", "niveaux"],
          enonce:           ["enonce", "question", "texte", "intitule", "libelle", "enonces"],
          reponse_correcte: ["reponse correcte", "bonne reponse", "reponse", "answer", "correcte", "solution"],
          distracteur_1:    ["distracteur 1", "distracteur1", "distract 1", "mauvaise reponse 1", "rep 2", "option 2"],
          distracteur_2:    ["distracteur 2", "distracteur2", "distract 2", "mauvaise reponse 2", "rep 3", "option 3"],
          distracteur_3:    ["distracteur 3", "distracteur3", "distract 3", "mauvaise reponse 3", "rep 4", "option 4"],
        };

        const findCol = (field: string): number => {
          const syns = SYNONYMS[field] || [field];
          for (const syn of syns) {
            const idx = fileHeaders.findIndex(h => h === syn || h.startsWith(syn) || syn.startsWith(h));
            if (idx !== -1) return idx;
          }
          // partial match fallback
          for (const syn of syns) {
            const idx = fileHeaders.findIndex(h => h.includes(syn) || syn.includes(h));
            if (idx !== -1) return idx;
          }
          return -1;
        };

        const colMap: Record<string, number> = {
          grand_theme:      findCol("grand_theme"),
          sous_theme:       findCol("sous_theme"),
          sous_sous_theme:  findCol("sous_sous_theme"),
          type:             findCol("type"),
          niveau:           findCol("niveau"),
          enonce:           findCol("enonce"),
          reponse_correcte: findCol("reponse_correcte"),
          distracteur_1:    findCol("distracteur_1"),
          distracteur_2:    findCol("distracteur_2"),
          distracteur_3:    findCol("distracteur_3"),
        };

        // Positional fallback if key columns not found (assume standard column order)
        const POSITIONAL = ["grand_theme","sous_theme","sous_sous_theme","type","niveau","enonce","reponse_correcte","distracteur_1","distracteur_2","distracteur_3"];
        const missingKey = ["enonce","type","niveau","grand_theme"].some(k => colMap[k] === -1);
        if (missingKey) {
          POSITIONAL.forEach((field, idx) => {
            if (colMap[field] === -1 && idx < (raw[0] as any[]).length) {
              colMap[field] = idx;
            }
          });
        }

        // Normalize type values from French labels to enum values
        const normalizeType = (raw: string): string => {
          const v = normalize(raw);
          if (v.includes("vrai") || v.includes("faux") || v === "v f" || v === "vf") return "TRUE_FALSE";
          if (v.includes("choix multiple") || v === "qcm") return "QCM";
          if (v.includes("trous") || v.includes("lacune")) return "OPEN";
          if (v.includes("scenario") || v.includes("scenar")) return "SCENARIO";
          if (v.includes("ouverte") || v.includes("open")) return "OPEN";
          if (v.includes("classement") || v.includes("ranking")) return "RANKING";
          // try direct enum match
          const upper = raw.trim().toUpperCase();
          if (QUESTION_TYPES.includes(upper)) return upper;
          return raw.trim().toUpperCase();
        };

        // Normalize level values (e.g. "1-FONDAMENTAL", "3-INTERMÉDIAIRE")
        const normalizeLevel = (raw: string): string => {
          const v = normalize(raw);
          // Strip leading "N-" prefix (e.g. "1-", "2-")
          const stripped = v.replace(/^\d+[\s\-–]+/, "").trim();
          if (stripped.includes("fondamental")) return "FONDAMENTAL";
          if (stripped.includes("base") || stripped.includes("basique")) return "BASIQUE";
          if (stripped.includes("intermediaire") || stripped.includes("intermed")) return "INTERMEDIAIRE";
          if (stripped.includes("avance") || stripped.includes("avancé")) return "AVANCE";
          if (stripped.includes("complet")) return "COMPLET";
          // try direct enum match
          const upper = raw.trim().toUpperCase();
          if (LEVELS.includes(upper)) return upper;
          return upper;
        };

        const rows: ImportQuestion[] = [];
        for (let i = 1; i < raw.length; i++) {
          const row = raw[i] as any[];
          if (!row || row.every(c => !c)) continue;

          const getValue = (field: string) => {
            const idx = colMap[field];
            if (idx === undefined || idx === -1) return "";
            const val = row[idx];
            return val != null ? String(val).trim() : "";
          };

          const enonce = getValue("enonce");
          const typeRaw = getValue("type");
          const niveauRaw = getValue("niveau");
          const grand_theme = getValue("grand_theme");
          const sous_theme = getValue("sous_theme");
          const sous_sous_theme = getValue("sous_sous_theme");

          const type = typeRaw ? normalizeType(typeRaw) : "";
          const niveau = niveauRaw ? normalizeLevel(niveauRaw) : "";

          let error = "";
          if (!enonce) error = "Énoncé manquant";
          else if (!type) error = "Type manquant";
          else if (!niveau) error = "Niveau manquant";
          else if (!grand_theme) error = "Grand thème manquant";
          else if (!sous_theme) error = "Sous-thème manquant";
          else if (!sous_sous_theme) error = "Sous-sous-thème manquant";
          else if (!QUESTION_TYPES.includes(type)) error = `Type invalide: ${typeRaw}`;
          else if (!LEVELS.includes(niveau)) error = `Niveau invalide: ${niveauRaw}`;

          rows.push({
            grand_theme,
            sous_theme,
            sous_sous_theme,
            type,
            niveau,
            enonce,
            reponse_correcte: getValue("reponse_correcte"),
            distracteur_1: getValue("distracteur_1"),
            distracteur_2: getValue("distracteur_2"),
            distracteur_3: getValue("distracteur_3"),
            _rowIndex: i + 1,
            _error: error || undefined,
          });
        }

        setImportRows(rows);
        setShowImportModal(true);
      } catch {
        toast.error("Erreur lors de la lecture du fichier");
      }
    };
    reader.readAsArrayBuffer(file);
  }

  async function handleImportConfirm() {
    const validRows = importRows.filter(r => !r._error);
    if (validRows.length === 0) {
      toast.error("Aucune ligne valide à importer");
      return;
    }
    setImportSaving(true);
    try {
      const res = await fetch("/api/super-admin/questions/import", {
        method: "POST",
        headers,
        body: JSON.stringify({ questions: validRows }),
      });
      if (!res.ok) throw new Error();
      const result = await res.json();
      toast.success(`${result.imported} question(s) importée(s) !`);
      if (result.skipped > 0) toast.error(`${result.skipped} erreur(s) d'import`);
      setShowImportModal(false);
      setImportRows([]);
      loadData();
    } catch {
      toast.error("Erreur lors de l'import");
    } finally {
      setImportSaving(false);
    }
  }

  function exportErrors() {
    const errorRows = importRows.filter(r => r._error);
    if (errorRows.length === 0) return;
    const ws = XLSX.utils.json_to_sheet(errorRows.map(r => ({
      "Ligne": r._rowIndex,
      "Grand thème": r.grand_theme,
      "Sous-thème": r.sous_theme,
      "Sous-sous-thème": r.sous_sous_theme,
      "Type": r.type,
      "Niveau": r.niveau,
      "Énoncé": r.enonce,
      "Erreur": r._error,
    })));
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, "Erreurs");
    XLSX.writeFile(wb, "erreurs_import_questions.xlsx");
  }

  const validImportCount = importRows.filter(r => !r._error).length;
  const errorImportCount = importRows.filter(r => r._error).length;

  return (
    <div className="flex h-screen overflow-hidden bg-gray-50">
      <Sidebar />
      <main className="flex-1 overflow-y-auto p-8">
        <div className="flex items-center justify-between mb-6">
          <h1 className="text-2xl font-bold" style={{ color: branding.primaryColor }}>
            Banque de questions
          </h1>
          <div className="flex gap-2 flex-wrap">
            <label className="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium border border-gray-300 hover:bg-gray-100 bg-white cursor-pointer">
              <FileSpreadsheet size={16} /> Importer des questions (.xlsx)
              <input
                ref={importFileRef}
                type="file"
                accept=".xlsx,.xls"
                className="hidden"
                onChange={e => {
                  const file = e.target.files?.[0];
                  if (file) parseQuestionsExcel(file);
                  e.target.value = "";
                }}
              />
            </label>
            <button
              onClick={() => setShowThemeModal(true)}
              className="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium border border-gray-300 hover:bg-gray-100 bg-white"
            >
              <Plus size={16} /> Thème
            </button>
            <button
              onClick={() => setShowSubThemeModal(true)}
              className="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium border border-gray-300 hover:bg-gray-100 bg-white"
            >
              <Plus size={16} /> Sous-thème
            </button>
            <button
              onClick={() => setShowSubSubThemeModal(true)}
              className="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium border border-gray-300 hover:bg-gray-100 bg-white"
            >
              <Plus size={16} /> Sous-sous-thème
            </button>
            <button
              onClick={() => { resetQuestionForm(); setShowQuestionModal(true); }}
              className="flex items-center gap-1 px-4 py-2 rounded-lg text-sm font-semibold text-white"
              style={{ backgroundColor: branding.primaryColor }}
            >
              <Plus size={16} /> Question
            </button>
          </div>
        </div>

        {/* Questions table */}
        <div className="bg-white rounded-xl shadow-sm overflow-hidden">
          {loading ? (
            <div className="p-8 text-center text-gray-400">Chargement...</div>
          ) : questions.length === 0 ? (
            <div className="p-8 text-center text-gray-400">Aucune question pour l'instant</div>
          ) : (
            <div className="overflow-x-auto">
              <table className="w-full text-sm">
                <thead>
                  <tr className="border-b bg-gray-50">
                    <th className="text-left px-4 py-3 font-semibold text-gray-600">Grand thème</th>
                    <th className="text-left px-4 py-3 font-semibold text-gray-600">Sous-thème</th>
                    <th className="text-left px-4 py-3 font-semibold text-gray-600">Sous-sous-thème</th>
                    <th className="text-left px-4 py-3 font-semibold text-gray-600">Question</th>
                    <th className="text-left px-4 py-3 font-semibold text-gray-600">Type</th>
                    <th className="text-left px-4 py-3 font-semibold text-gray-600">Niveau</th>
                    <th className="text-left px-4 py-3 font-semibold text-gray-600">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {questions.map(q => (
                    <tr key={q.id} className="border-b hover:bg-gray-50 transition-colors">
                      <td className="px-4 py-3 text-gray-700">{q.subSubTheme?.subTheme?.theme?.label || "-"}</td>
                      <td className="px-4 py-3 text-gray-700">{q.subSubTheme?.subTheme?.label || "-"}</td>
                      <td className="px-4 py-3 text-gray-700">{q.subSubTheme?.label || "-"}</td>
                      <td className="px-4 py-3 text-gray-700 max-w-xs truncate">{q.text}</td>
                      <td className="px-4 py-3">
                        <span className="px-2 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                          {typeLabels[q.type] || q.type}
                        </span>
                      </td>
                      <td className="px-4 py-3">
                        <span className="px-2 py-1 rounded-full text-xs font-medium bg-purple-50 text-purple-700">
                          {levelLabels[q.level] || q.level}
                        </span>
                      </td>
                      <td className="px-4 py-3">
                        <button
                          onClick={() => openEditQuestion(q)}
                          className="p-1.5 rounded-lg hover:bg-gray-100 text-gray-500 hover:text-gray-700"
                          aria-label="Modifier"
                        >
                          <Pencil size={15} />
                        </button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </main>

      {/* Import Questions Modal */}
      {showImportModal && (
        <Modal title="Import questions (.xlsx) – Aperçu" onClose={() => setShowImportModal(false)} wide>
          <div className="space-y-4">
            {/* Summary */}
            <div className="flex gap-3">
              <div className="flex-1 bg-green-50 border border-green-200 rounded-lg p-3 text-center">
                <p className="text-2xl font-bold text-green-700">{validImportCount}</p>
                <p className="text-xs text-green-600">ligne(s) valide(s)</p>
              </div>
              {errorImportCount > 0 && (
                <div className="flex-1 bg-red-50 border border-red-200 rounded-lg p-3 text-center">
                  <p className="text-2xl font-bold text-red-700">{errorImportCount}</p>
                  <p className="text-xs text-red-600">ligne(s) en erreur</p>
                </div>
              )}
            </div>

            {/* Format hint */}
            <div className="bg-blue-50 border border-blue-200 rounded-lg p-3 text-xs text-blue-700">
              <strong>Colonnes attendues :</strong> grand_theme | sous_theme | sous_sous_theme | type | niveau | enonce | reponse_correcte | distracteur_1 | distracteur_2 | distracteur_3
            </div>

            {/* Preview table */}
            <div className="overflow-x-auto rounded-lg border border-gray-200">
              <table className="w-full text-xs">
                <thead className="bg-gray-50">
                  <tr>
                    <th className="px-3 py-2 text-left font-semibold text-gray-600">#</th>
                    <th className="px-3 py-2 text-left font-semibold text-gray-600">Grand thème</th>
                    <th className="px-3 py-2 text-left font-semibold text-gray-600">Sous-thème</th>
                    <th className="px-3 py-2 text-left font-semibold text-gray-600">Sous-sous-thème</th>
                    <th className="px-3 py-2 text-left font-semibold text-gray-600">Type</th>
                    <th className="px-3 py-2 text-left font-semibold text-gray-600">Niveau</th>
                    <th className="px-3 py-2 text-left font-semibold text-gray-600 max-w-[200px]">Énoncé</th>
                    <th className="px-3 py-2 text-left font-semibold text-gray-600">Statut</th>
                  </tr>
                </thead>
                <tbody>
                  {importRows.map((row, idx) => (
                    <tr key={idx} className={`border-t ${row._error ? "bg-red-50" : "hover:bg-gray-50"}`}>
                      <td className="px-3 py-2 text-gray-500">{row._rowIndex}</td>
                      <td className="px-3 py-2">{row.grand_theme || "—"}</td>
                      <td className="px-3 py-2">{row.sous_theme || "—"}</td>
                      <td className="px-3 py-2">{row.sous_sous_theme || "—"}</td>
                      <td className="px-3 py-2">{row.type || "—"}</td>
                      <td className="px-3 py-2">{row.niveau || "—"}</td>
                      <td className="px-3 py-2 max-w-[200px] truncate">{row.enonce || "—"}</td>
                      <td className="px-3 py-2">
                        {row._error ? (
                          <div className="flex items-center gap-1 text-red-600">
                            <AlertTriangle size={12} />
                            <span>{row._error}</span>
                          </div>
                        ) : (
                          <span className="text-green-600 font-medium">OK</span>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div className="flex justify-between gap-2">
              <div>
                {errorImportCount > 0 && (
                  <button
                    onClick={exportErrors}
                    className="flex items-center gap-2 px-3 py-2 rounded-lg border border-red-300 text-red-600 text-sm hover:bg-red-50"
                  >
                    <Download size={15} /> Exporter les erreurs
                  </button>
                )}
              </div>
              <div className="flex gap-2">
                <button type="button" onClick={() => setShowImportModal(false)}
                  className="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50">
                  Annuler
                </button>
                <button
                  onClick={handleImportConfirm}
                  disabled={importSaving || validImportCount === 0}
                  className="flex items-center gap-2 px-4 py-2 rounded-lg text-white text-sm font-semibold disabled:opacity-50"
                  style={{ backgroundColor: branding.primaryColor }}
                >
                  <Upload size={15} />
                  {importSaving ? "Import en cours..." : `Confirmer l'import (${validImportCount})`}
                </button>
              </div>
            </div>
          </div>
        </Modal>
      )}

      {/* Create Theme Modal */}
      {showThemeModal && (
        <Modal title="Nouveau thème" onClose={() => setShowThemeModal(false)}>
          <form onSubmit={handleCreateTheme} className="space-y-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">Libellé</label>
              <input
                type="text"
                value={themeLabel}
                onChange={e => setThemeLabel(e.target.value)}
                className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2"
                placeholder="Nom du thème"
                required
              />
            </div>
            <div className="flex justify-end gap-2">
              <button type="button" onClick={() => setShowThemeModal(false)} className="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50">
                Annuler
              </button>
              <button type="submit" className="px-4 py-2 rounded-lg text-white text-sm font-semibold" style={{ backgroundColor: branding.primaryColor }}>
                Créer
              </button>
            </div>
          </form>
        </Modal>
      )}

      {/* Create Sub-theme Modal */}
      {showSubThemeModal && (
        <Modal title="Nouveau sous-thème" onClose={() => setShowSubThemeModal(false)}>
          <form onSubmit={handleCreateSubTheme} className="space-y-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">Grand thème</label>
              <select
                value={subThemeThemeId}
                onChange={e => setSubThemeThemeId(e.target.value)}
                className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none"
                required
              >
                <option value="">Sélectionner un thème</option>
                {themes.map(t => <option key={t.id} value={t.id}>{t.label}</option>)}
              </select>
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">Libellé</label>
              <input
                type="text"
                value={subThemeLabel}
                onChange={e => setSubThemeLabel(e.target.value)}
                className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none"
                placeholder="Nom du sous-thème"
                required
              />
            </div>
            <div className="flex justify-end gap-2">
              <button type="button" onClick={() => setShowSubThemeModal(false)} className="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50">
                Annuler
              </button>
              <button type="submit" className="px-4 py-2 rounded-lg text-white text-sm font-semibold" style={{ backgroundColor: branding.primaryColor }}>
                Créer
              </button>
            </div>
          </form>
        </Modal>
      )}

      {/* Create Sub-sub-theme Modal */}
      {showSubSubThemeModal && (
        <Modal title="Nouveau sous-sous-thème" onClose={() => setShowSubSubThemeModal(false)}>
          <form onSubmit={handleCreateSubSubTheme} className="space-y-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">Sous-thème parent</label>
              <select
                value={subSubThemeSubThemeId}
                onChange={e => setSubSubThemeSubThemeId(e.target.value)}
                className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none"
                required
              >
                <option value="">Sélectionner un sous-thème</option>
                {allSubThemes.map(s => (
                  <option key={s.id} value={s.id}>
                    {themes.find(t => t.id === s.themeId)?.label} → {s.label}
                  </option>
                ))}
              </select>
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">Libellé</label>
              <input
                type="text"
                value={subSubThemeLabel}
                onChange={e => setSubSubThemeLabel(e.target.value)}
                className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none"
                placeholder="Nom du sous-sous-thème"
                required
              />
            </div>
            <div className="flex justify-end gap-2">
              <button type="button" onClick={() => setShowSubSubThemeModal(false)} className="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50">
                Annuler
              </button>
              <button type="submit" className="px-4 py-2 rounded-lg text-white text-sm font-semibold" style={{ backgroundColor: branding.primaryColor }}>
                Créer
              </button>
            </div>
          </form>
        </Modal>
      )}

      {/* Create/Edit Question Modal */}
      {showQuestionModal && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-xl shadow-xl w-full max-w-2xl max-h-[90vh] flex flex-col">
            <div className="flex items-center justify-between p-5 border-b">
              <h2 className="text-lg font-semibold">{editingQuestion ? "Modifier la question" : "Nouvelle question"}</h2>
              <button onClick={() => { setShowQuestionModal(false); resetQuestionForm(); }} className="text-gray-400 hover:text-gray-600">
                <X size={20} />
              </button>
            </div>
            <div className="flex-1 overflow-y-auto p-5">
              <form onSubmit={handleSaveQuestion} className="space-y-4">
                {/* Theme/SubTheme/SubSubTheme selects */}
                <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Grand thème</label>
                    <select
                      value={qThemeId}
                      onChange={e => { setQThemeId(e.target.value); setQSubThemeId(""); setQSubSubThemeId(""); }}
                      className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none"
                      required
                    >
                      <option value="">Choisir</option>
                      {themes.map(t => <option key={t.id} value={t.id}>{t.label}</option>)}
                    </select>
                  </div>
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Sous-thème</label>
                    <select
                      value={qSubThemeId}
                      onChange={e => { setQSubThemeId(e.target.value); setQSubSubThemeId(""); }}
                      className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none"
                      required
                    >
                      <option value="">Choisir</option>
                      {subThemesForSelected.map(s => <option key={s.id} value={s.id}>{s.label}</option>)}
                    </select>
                  </div>
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Sous-sous-thème</label>
                    <select
                      value={qSubSubThemeId}
                      onChange={e => setQSubSubThemeId(e.target.value)}
                      className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none"
                      required
                    >
                      <option value="">Choisir</option>
                      {subSubThemesForSelected.map(s => <option key={s.id} value={s.id}>{s.label}</option>)}
                    </select>
                  </div>
                </div>

                {/* Type and Level */}
                <div className="grid grid-cols-2 gap-3">
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Type de question</label>
                    <select
                      value={qType}
                      onChange={e => setQType(e.target.value)}
                      className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none"
                    >
                      {QUESTION_TYPES.map(t => <option key={t} value={t}>{typeLabels[t]}</option>)}
                    </select>
                  </div>
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Niveau</label>
                    <select
                      value={qLevel}
                      onChange={e => setQLevel(e.target.value)}
                      className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none"
                    >
                      {LEVELS.map(l => <option key={l} value={l}>{levelLabels[l]}</option>)}
                    </select>
                  </div>
                </div>

                {/* Question text */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">Énoncé de la question</label>
                  <textarea
                    value={qText}
                    onChange={e => setQText(e.target.value)}
                    rows={3}
                    className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none resize-none"
                    placeholder="Saisir la question..."
                    required
                  />
                </div>

                {/* Dynamic answer zone */}
                {qType === "QCM" && (
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-2">Propositions (cocher la bonne réponse)</label>
                    <div className="space-y-2">
                      {qOptions.map((opt, idx) => (
                        <div key={idx} className="flex items-center gap-2">
                          <input
                            type="radio"
                            name="correct"
                            checked={qCorrectOption === idx}
                            onChange={() => setQCorrectOption(idx)}
                            className="mt-0.5"
                          />
                          <input
                            type="text"
                            value={opt}
                            onChange={e => {
                              const updated = [...qOptions];
                              updated[idx] = e.target.value;
                              setQOptions(updated);
                            }}
                            className="flex-1 border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none"
                            placeholder={`Option ${idx + 1}`}
                          />
                          {qOptions.length > 2 && (
                            <button type="button" onClick={() => setQOptions(qOptions.filter((_, i) => i !== idx))} className="text-red-400 hover:text-red-600">
                              <X size={15} />
                            </button>
                          )}
                        </div>
                      ))}
                      <button
                        type="button"
                        onClick={() => setQOptions([...qOptions, ""])}
                        className="text-sm text-blue-600 hover:text-blue-800 flex items-center gap-1"
                      >
                        <Plus size={14} /> Ajouter une option
                      </button>
                    </div>
                  </div>
                )}

                {qType === "TRUE_FALSE" && (
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-2">Bonne réponse</label>
                    <div className="flex gap-4">
                      <label className="flex items-center gap-2 text-sm">
                        <input type="radio" checked={qTrueFalse === "true"} onChange={() => setQTrueFalse("true")} />
                        Vrai
                      </label>
                      <label className="flex items-center gap-2 text-sm">
                        <input type="radio" checked={qTrueFalse === "false"} onChange={() => setQTrueFalse("false")} />
                        Faux
                      </label>
                    </div>
                  </div>
                )}

                {(qType === "OPEN" || qType === "SCENARIO") && (
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Réponse attendue / Éléments de correction</label>
                    <textarea
                      value={qExpectedAnswer}
                      onChange={e => setQExpectedAnswer(e.target.value)}
                      rows={3}
                      className="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none resize-none"
                      placeholder="Décrire la réponse attendue..."
                    />
                  </div>
                )}

                {qType === "RANKING" && (
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-2">Éléments à classer (ordre correct de haut en bas)</label>
                    <div className="space-y-2">
                      {qRankingItems.map((item, idx) => (
                        <div key={idx} className="flex items-center gap-2">
                          <span className="text-sm text-gray-400 w-5">{idx + 1}.</span>
                          <input
                            type="text"
                            value={item}
                            onChange={e => {
                              const updated = [...qRankingItems];
                              updated[idx] = e.target.value;
                              setQRankingItems(updated);
                            }}
                            className="flex-1 border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none"
                            placeholder={`Élément ${idx + 1}`}
                          />
                          {qRankingItems.length > 2 && (
                            <button type="button" onClick={() => setQRankingItems(qRankingItems.filter((_, i) => i !== idx))} className="text-red-400 hover:text-red-600">
                              <X size={15} />
                            </button>
                          )}
                        </div>
                      ))}
                      <button
                        type="button"
                        onClick={() => setQRankingItems([...qRankingItems, ""])}
                        className="text-sm text-blue-600 hover:text-blue-800 flex items-center gap-1"
                      >
                        <Plus size={14} /> Ajouter un élément
                      </button>
                    </div>
                  </div>
                )}

                <div className="flex justify-end gap-2 pt-2">
                  <button
                    type="button"
                    onClick={() => { setShowQuestionModal(false); resetQuestionForm(); }}
                    className="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50"
                  >
                    Annuler
                  </button>
                  <button
                    type="submit"
                    disabled={saving}
                    className="px-4 py-2 rounded-lg text-white text-sm font-semibold disabled:opacity-50"
                    style={{ backgroundColor: branding.primaryColor }}
                  >
                    {saving ? "Enregistrement..." : editingQuestion ? "Modifier" : "Créer"}
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
