          { "name": "model", "type": "select", "label": "Model" },
          { "name": "max_tokens", "type": "integer", "label": "Max tokens" },
          { "name": "system", "type": "text", "label": "System prompt" },
          { "name": "messages", "type": "array", "label": "Messages" }
        ]
